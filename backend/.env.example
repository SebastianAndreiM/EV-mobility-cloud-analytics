# --- App ---
APP_NAME=EV Mobility Cloud Analytics
ENV=development
DEBUG=true

# --- Security ---
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database (canonical; drivers derived automatically) ---
# Host = docker-compose service name "db"
DATABASE_URL=postgresql://ev_user:ev_pass@db:5432/ev_analytics
POSTGRES_USER=ev_user
POSTGRES_PASSWORD=ev_pass
POSTGRES_DB=ev_analytics

# --- Redis (separate DB indices) ---
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_REDIS_URL=redis://redis:6379/2

# --- RabbitMQ / Celery broker (note trailing // = default vhost) ---
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# --- CORS (frontend origin as seen by the browser) ---
CORS_ORIGINS=http://localhost:5173

# --- Frontend build-time (used by frontend service) ---
VITE_API_BASE_URL=http://localhost:8000
